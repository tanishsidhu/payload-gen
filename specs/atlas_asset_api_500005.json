{
  "seed": 500005,
  "spec": {
    "api_name": "Atlas Asset API",
    "version": "3.8",
    "endpoints": [
      {
        "operation": "post_receipt",
        "method": "POST",
        "path": "/post-receipt/execute",
        "fields": [
          {
            "name": "deposit_date",
            "type": "date",
            "required": true
          },
          {
            "name": "remitter_ref",
            "type": "string",
            "required": false
          },
          {
            "name": "agreement_no",
            "type": "string",
            "required": true
          },
          {
            "name": "cash_received",
            "type": "integer",
            "required": true,
            "unit": "dollars"
          }
        ]
      },
      {
        "operation": "amend_contract",
        "method": "POST",
        "path": "/v2/amend-contract/execute",
        "fields": [
          {
            "name": "lease_id",
            "type": "string",
            "required": true
          },
          {
            "name": "modification_kind",
            "type": "enum",
            "required": true,
            "enum": [
              "rate_change",
              "term_extension",
              "party_change",
              "covenant_update"
            ]
          },
          {
            "name": "terms",
            "type": "object",
            "required": true,
            "fields": [
              {
                "name": "updated_conditions",
                "type": "string",
                "required": false
              },
              {
                "name": "posting_date",
                "type": "date",
                "required": true
              }
            ]
          }
        ]
      },
      {
        "operation": "create_asset",
        "method": "POST",
        "path": "/create-asset",
        "fields": [
          {
            "name": "asset_type",
            "type": "enum",
            "required": true,
            "enum": [
              "vehicle",
              "equipment",
              "aircraft",
              "real_estate"
            ]
          },
          {
            "name": "purchase_date",
            "type": "date",
            "required": true
          },
          {
            "name": "payment_info",
            "type": "object",
            "required": true,
            "fields": [
              {
                "name": "asset_ref",
                "type": "string",
                "required": true
              },
              {
                "name": "purchase_price",
                "type": "integer",
                "required": true,
                "unit": "cents"
              }
            ]
          }
        ]
      },
      {
        "operation": "book_lease",
        "method": "POST",
        "path": "/v1/book-lease/execute",
        "fields": [
          {
            "name": "asset_id",
            "type": "string",
            "required": true
          },
          {
            "name": "commencement_date",
            "type": "date",
            "required": true
          },
          {
            "name": "contract_id",
            "type": "string",
            "required": true
          },
          {
            "name": "borrower_name",
            "type": "string",
            "required": true
          },
          {
            "name": "end_date",
            "type": "date",
            "required": false
          },
          {
            "name": "installment_amount",
            "type": "integer",
            "required": true,
            "unit": "dollars"
          }
        ]
      }
    ]
  },
  "spec_text": "API: Atlas Asset API v3.8\n\nPOST /post-receipt/execute  (post_receipt)\n  deposit_date (date, required)\n  remitter_ref (string, optional)\n  agreement_no (string, required)\n  cash_received (integer, unit=dollars, required)\n\nPOST /v2/amend-contract/execute  (amend_contract)\n  lease_id (string, required)\n  modification_kind (enum ['rate_change', 'term_extension', 'party_change', 'covenant_update'], required)\n  terms (object, required):\n    updated_conditions (string, optional)\n    posting_date (date, required)\n\nPOST /create-asset  (create_asset)\n  asset_type (enum ['vehicle', 'equipment', 'aircraft', 'real_estate'], required)\n  purchase_date (date, required)\n  payment_info (object, required):\n    asset_ref (string, required)\n    purchase_price (integer, unit=cents, required)\n\nPOST /v1/book-lease/execute  (book_lease)\n  asset_id (string, required)\n  commencement_date (date, required)\n  contract_id (string, required)\n  borrower_name (string, required)\n  end_date (date, optional)\n  installment_amount (integer, unit=dollars, required)"
}