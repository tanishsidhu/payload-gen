{
  "seed": 500012,
  "spec": {
    "api_name": "Atlas Asset API",
    "version": "1.1",
    "endpoints": [
      {
        "operation": "post_receipt",
        "method": "POST",
        "path": "/v2/post-receipt",
        "fields": [
          {
            "name": "source_ref",
            "type": "string",
            "required": false
          },
          {
            "name": "receipt_amount",
            "type": "integer",
            "required": true,
            "unit": "cents"
          },
          {
            "name": "agreement_no",
            "type": "string",
            "required": true
          },
          {
            "name": "received_date",
            "type": "date",
            "required": true
          }
        ]
      },
      {
        "operation": "book_lease",
        "method": "POST",
        "path": "/v2/book-lease/submit",
        "fields": [
          {
            "name": "contract_id",
            "type": "string",
            "required": true
          },
          {
            "name": "asset_tag",
            "type": "string",
            "required": true
          },
          {
            "name": "customer_name",
            "type": "string",
            "required": true
          },
          {
            "name": "lease_start",
            "type": "date",
            "required": true
          },
          {
            "name": "terms",
            "type": "object",
            "required": true,
            "fields": [
              {
                "name": "monthly_payment",
                "type": "integer",
                "required": true,
                "unit": "dollars"
              },
              {
                "name": "end_date",
                "type": "date",
                "required": false
              }
            ]
          }
        ]
      },
      {
        "operation": "amend_contract",
        "method": "POST",
        "path": "/v2/amend-contract",
        "fields": [
          {
            "name": "revised_clause",
            "type": "string",
            "required": false
          },
          {
            "name": "agreement_no",
            "type": "string",
            "required": true
          },
          {
            "name": "modification_kind",
            "type": "enum",
            "required": true,
            "enum": [
              "rate_change",
              "term_extension",
              "party_change",
              "covenant_update"
            ]
          },
          {
            "name": "effective_date",
            "type": "date",
            "required": true
          }
        ]
      }
    ]
  },
  "spec_text": "API: Atlas Asset API v1.1\n\nPOST /v2/post-receipt  (post_receipt)\n  source_ref (string, optional)\n  receipt_amount (integer, unit=cents, required)\n  agreement_no (string, required)\n  received_date (date, required)\n\nPOST /v2/book-lease/submit  (book_lease)\n  contract_id (string, required)\n  asset_tag (string, required)\n  customer_name (string, required)\n  lease_start (date, required)\n  terms (object, required):\n    monthly_payment (integer, unit=dollars, required)\n    end_date (date, optional)\n\nPOST /v2/amend-contract  (amend_contract)\n  revised_clause (string, optional)\n  agreement_no (string, required)\n  modification_kind (enum ['rate_change', 'term_extension', 'party_change', 'covenant_update'], required)\n  effective_date (date, required)"
}