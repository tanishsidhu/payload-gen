{
  "seed": 500009,
  "spec": {
    "api_name": "Northwind Capital API",
    "version": "1.1",
    "endpoints": [
      {
        "operation": "post_receipt",
        "method": "POST",
        "path": "/post-receipt",
        "fields": [
          {
            "name": "cash_received",
            "type": "integer",
            "required": true,
            "unit": "dollars"
          },
          {
            "name": "received_date",
            "type": "date",
            "required": true
          },
          {
            "name": "source_ref",
            "type": "string",
            "required": false
          },
          {
            "name": "contract_ref",
            "type": "string",
            "required": true
          }
        ]
      },
      {
        "operation": "create_asset",
        "method": "POST",
        "path": "/v2/create-asset/submit",
        "fields": [
          {
            "name": "asset_tag",
            "type": "string",
            "required": true
          },
          {
            "name": "category",
            "type": "enum",
            "required": true,
            "enum": [
              "vehicle",
              "equipment",
              "aircraft",
              "real_estate"
            ]
          },
          {
            "name": "purchase_date",
            "type": "date",
            "required": true
          },
          {
            "name": "purchase_price",
            "type": "integer",
            "required": true,
            "unit": "dollars"
          }
        ]
      },
      {
        "operation": "book_lease",
        "method": "POST",
        "path": "/v2/book-lease/submit",
        "fields": [
          {
            "name": "contract_id",
            "type": "string",
            "required": true
          },
          {
            "name": "lessee_name",
            "type": "string",
            "required": true
          },
          {
            "name": "maturity_date",
            "type": "date",
            "required": false
          },
          {
            "name": "monthly_payment",
            "type": "integer",
            "required": true,
            "unit": "dollars"
          },
          {
            "name": "lease_start",
            "type": "date",
            "required": true
          },
          {
            "name": "asset_tag",
            "type": "string",
            "required": true
          }
        ]
      },
      {
        "operation": "amend_contract",
        "method": "POST",
        "path": "/v1/amend-contract/execute",
        "fields": [
          {
            "name": "modification_kind",
            "type": "enum",
            "required": true,
            "enum": [
              "rate_change",
              "term_extension",
              "party_change",
              "covenant_update"
            ]
          },
          {
            "name": "new_terms",
            "type": "string",
            "required": false
          },
          {
            "name": "effective_date",
            "type": "date",
            "required": true
          },
          {
            "name": "contract_id",
            "type": "string",
            "required": true
          }
        ]
      }
    ]
  },
  "spec_text": "API: Northwind Capital API v1.1\n\nPOST /post-receipt  (post_receipt)\n  cash_received (integer, unit=dollars, required)\n  received_date (date, required)\n  source_ref (string, optional)\n  contract_ref (string, required)\n\nPOST /v2/create-asset/submit  (create_asset)\n  asset_tag (string, required)\n  category (enum ['vehicle', 'equipment', 'aircraft', 'real_estate'], required)\n  purchase_date (date, required)\n  purchase_price (integer, unit=dollars, required)\n\nPOST /v2/book-lease/submit  (book_lease)\n  contract_id (string, required)\n  lessee_name (string, required)\n  maturity_date (date, optional)\n  monthly_payment (integer, unit=dollars, required)\n  lease_start (date, required)\n  asset_tag (string, required)\n\nPOST /v1/amend-contract/execute  (amend_contract)\n  modification_kind (enum ['rate_change', 'term_extension', 'party_change', 'covenant_update'], required)\n  new_terms (string, optional)\n  effective_date (date, required)\n  contract_id (string, required)"
}