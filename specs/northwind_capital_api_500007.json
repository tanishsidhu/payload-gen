{
  "seed": 500007,
  "spec": {
    "api_name": "Northwind Capital API",
    "version": "2.1",
    "endpoints": [
      {
        "operation": "post_receipt",
        "method": "POST",
        "path": "/v1/post-receipt/execute",
        "fields": [
          {
            "name": "collection_date",
            "type": "date",
            "required": true
          },
          {
            "name": "agreement_no",
            "type": "string",
            "required": true
          },
          {
            "name": "metadata",
            "type": "object",
            "required": true,
            "fields": [
              {
                "name": "payer_reference",
                "type": "string",
                "required": false
              },
              {
                "name": "collected_amount",
                "type": "integer",
                "required": true,
                "unit": "cents"
              }
            ]
          }
        ]
      },
      {
        "operation": "book_lease",
        "method": "POST",
        "path": "/v1/book-lease",
        "fields": [
          {
            "name": "rent_amount",
            "type": "integer",
            "required": true,
            "unit": "cents"
          },
          {
            "name": "lease_start",
            "type": "date",
            "required": true
          },
          {
            "name": "borrower_name",
            "type": "string",
            "required": true
          },
          {
            "name": "agreement_no",
            "type": "string",
            "required": true
          },
          {
            "name": "details",
            "type": "object",
            "required": true,
            "fields": [
              {
                "name": "end_date",
                "type": "date",
                "required": false
              },
              {
                "name": "equipment_code",
                "type": "string",
                "required": true
              }
            ]
          }
        ]
      },
      {
        "operation": "create_asset",
        "method": "POST",
        "path": "/v1/create-asset",
        "fields": [
          {
            "name": "acquisition_date",
            "type": "date",
            "required": true
          },
          {
            "name": "asset_tag",
            "type": "string",
            "required": true
          },
          {
            "name": "metadata",
            "type": "object",
            "required": true,
            "fields": [
              {
                "name": "purchase_price",
                "type": "integer",
                "required": true,
                "unit": "dollars"
              },
              {
                "name": "category",
                "type": "enum",
                "required": true,
                "enum": [
                  "vehicle",
                  "equipment",
                  "aircraft",
                  "real_estate"
                ]
              }
            ]
          }
        ]
      },
      {
        "operation": "amend_contract",
        "method": "POST",
        "path": "/amend-contract/execute",
        "fields": [
          {
            "name": "lease_id",
            "type": "string",
            "required": true
          },
          {
            "name": "effective_date",
            "type": "date",
            "required": true
          },
          {
            "name": "amendment_type",
            "type": "enum",
            "required": true,
            "enum": [
              "rate_change",
              "term_extension",
              "party_change",
              "covenant_update"
            ]
          },
          {
            "name": "new_terms",
            "type": "string",
            "required": false
          }
        ]
      }
    ]
  },
  "spec_text": "API: Northwind Capital API v2.1\n\nPOST /v1/post-receipt/execute  (post_receipt)\n  collection_date (date, required)\n  agreement_no (string, required)\n  metadata (object, required):\n    payer_reference (string, optional)\n    collected_amount (integer, unit=cents, required)\n\nPOST /v1/book-lease  (book_lease)\n  rent_amount (integer, unit=cents, required)\n  lease_start (date, required)\n  borrower_name (string, required)\n  agreement_no (string, required)\n  details (object, required):\n    end_date (date, optional)\n    equipment_code (string, required)\n\nPOST /v1/create-asset  (create_asset)\n  acquisition_date (date, required)\n  asset_tag (string, required)\n  metadata (object, required):\n    purchase_price (integer, unit=dollars, required)\n    category (enum ['vehicle', 'equipment', 'aircraft', 'real_estate'], required)\n\nPOST /amend-contract/execute  (amend_contract)\n  lease_id (string, required)\n  effective_date (date, required)\n  amendment_type (enum ['rate_change', 'term_extension', 'party_change', 'covenant_update'], required)\n  new_terms (string, optional)"
}